{
  "type": "APL",
  "version": "2023.3",
  "theme": "dark",
  "settings": { "idleTimeout": 60000 },
  "resources": [
    {
      "colors": {
        "colorBg": "#0a0c12",
        "colorSurface2": "#191d2a",
        "colorLine": "#272c3b",
        "colorText": "#eef0f7",
        "colorMuted": "#949bb2",
        "colorBrand": "#7c8cff",
        "colorOk": "#46d787",
        "colorWarn": "#f7b53b",
        "colorCrit": "#fb5a76",
        "colorIdle": "#5b6072",
        "colorTrack": "#2a3040"
      }
    }
  ],
  "graphics": {
    "RingGraphic": {
      "type": "AVG",
      "version": "1.2",
      "width": 150,
      "height": 150,
      "viewportWidth": 150,
      "viewportHeight": 150,
      "parameters": [
        { "name": "pct", "type": "number", "default": 0 },
        { "name": "arcColor", "type": "color", "default": "#46d787" },
        { "name": "trackColor", "type": "color", "default": "#2a3040" }
      ],
      "items": [
        { "type": "path", "pathData": "M75 13 A62 62 0 0 1 75 137 A62 62 0 0 1 75 13", "stroke": "${trackColor}", "strokeWidth": 13, "fill": "transparent" },
        { "type": "path", "pathData": "M75 13 A62 62 0 0 1 75 137 A62 62 0 0 1 75 13", "stroke": "${arcColor}", "strokeWidth": 13, "strokeLineCap": "round", "fill": "transparent", "strokeDashArray": [ "${389.56 * pct / 100}", 389.56 ] }
      ]
    }
  },
  "layouts": {
    "StatusDot": {
      "parameters": [ { "name": "level", "type": "string", "default": "ok" } ],
      "items": [
        { "type": "Frame", "width": 12, "height": 12, "borderRadius": 6, "backgroundColor": "${level == 'crit' ? @colorCrit : level == 'warn' ? @colorWarn : level == 'idle' ? @colorIdle : @colorOk}" }
      ]
    },
    "RingGauge": {
      "parameters": [
        { "name": "pct", "type": "number", "default": 0 },
        { "name": "value", "type": "string", "default": "0" },
        { "name": "label", "type": "string", "default": "" },
        { "name": "sub", "type": "string", "default": "" },
        { "name": "level", "type": "string", "default": "ok" }
      ],
      "items": [
        {
          "type": "Container", "grow": 1, "alignItems": "center", "justifyContent": "center", "paddingTop": 8, "paddingBottom": 8,
          "items": [
            {
              "type": "Container", "width": 128, "height": 128,
              "items": [
                { "type": "VectorGraphic", "source": "RingGraphic", "position": "absolute", "left": 0, "top": 0, "width": 128, "height": 128, "scale": "best-fit", "pct": "${pct}", "arcColor": "${level == 'crit' ? @colorCrit : level == 'warn' ? @colorWarn : @colorOk}", "trackColor": "@colorTrack" },
                { "type": "Container", "position": "absolute", "left": 0, "top": 0, "width": 128, "height": 128, "justifyContent": "center", "alignItems": "center",
                  "items": [
                    { "type": "Text", "text": "${value}%", "fontSize": 32, "fontWeight": "800", "color": "@colorText" },
                    { "type": "Text", "text": "${label}", "fontSize": 12, "letterSpacing": 2, "color": "@colorMuted" }
                  ]
                }
              ]
            },
            { "type": "Text", "text": "${sub}", "fontSize": 14, "color": "@colorMuted", "textAlign": "center", "paddingTop": 10, "maxLines": 1 }
          ]
        }
      ]
    },
    "MetricBar": {
      "parameters": [
        { "name": "label", "type": "string", "default": "" },
        { "name": "value", "type": "string", "default": "0" },
        { "name": "bar", "type": "number", "default": 0 }
      ],
      "items": [
        {
          "type": "Container", "width": 210,
          "items": [
            { "type": "Container", "direction": "row", "justifyContent": "spaceBetween", "alignItems": "baseline",
              "items": [
                { "type": "Text", "text": "${label}", "fontSize": 12, "letterSpacing": 2, "color": "@colorMuted" },
                { "type": "Text", "text": "${value}%", "fontSize": 16, "fontWeight": "600", "color": "@colorText" }
              ]
            },
            { "type": "Frame", "spacing": 5, "width": "100%", "height": 6, "borderRadius": 3, "backgroundColor": "@colorTrack",
              "items": [ { "type": "Frame", "width": "${bar}%", "height": 6, "borderRadius": 3, "backgroundColor": "@colorBrand" } ]
            }
          ]
        }
      ]
    },
    "ContainerRow": {
      "parameters": [
        { "name": "name", "type": "string", "default": "" },
        { "name": "sub", "type": "string", "default": "" },
        { "name": "level", "type": "string", "default": "ok" },
        { "name": "cpu", "type": "string", "default": "0" },
        { "name": "cpuBar", "type": "number", "default": 0 },
        { "name": "mem", "type": "string", "default": "0" },
        { "name": "memBar", "type": "number", "default": 0 }
      ],
      "items": [
        {
          "type": "Frame", "width": "100%", "borderRadius": 12, "borderWidth": 1, "borderColor": "@colorLine", "backgroundColor": "@colorSurface2", "paddingLeft": 18, "paddingRight": 22, "paddingTop": 12, "paddingBottom": 12,
          "items": [
            {
              "type": "Container", "direction": "row", "alignItems": "center", "width": "100%", "spacing": 20,
              "items": [
                { "type": "StatusDot", "level": "${level}" },
                { "type": "Container", "grow": 1, "shrink": 1,
                  "items": [
                    { "type": "Text", "text": "${name}", "fontSize": 22, "fontWeight": "700", "color": "@colorText", "maxLines": 1 },
                    { "type": "Text", "text": "${sub}", "fontSize": 14, "color": "@colorMuted", "maxLines": 1 }
                  ]
                },
                { "type": "MetricBar", "label": "CPU", "value": "${cpu}", "bar": "${cpuBar}" },
                { "type": "MetricBar", "label": "MEM", "value": "${mem}", "bar": "${memBar}" }
              ]
            }
          ]
        }
      ]
    },
    "OverviewPage": {
      "parameters": [ { "name": "status" } ],
      "items": [
        {
          "type": "Container", "width": "100%", "height": "100%", "paddingLeft": 40, "paddingRight": 40, "paddingTop": 22, "paddingBottom": 18,
          "items": [
            {
              "type": "Container", "direction": "row", "alignItems": "center", "justifyContent": "spaceBetween", "width": "100%",
              "items": [
                { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 14,
                  "items": [
                    { "type": "Frame", "width": 30, "height": 30, "borderRadius": 9, "backgroundColor": "@colorBrand" },
                    { "type": "Container",
                      "items": [
                        { "type": "Text", "text": "${status.host}", "fontSize": 28, "fontWeight": "800", "color": "@colorText" },
                        { "type": "Text", "text": "${status.hostname}", "fontSize": 13, "letterSpacing": 2, "color": "@colorMuted" }
                      ]
                    }
                  ]
                },
                { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 18,
                  "items": [
                    { "type": "Text", "text": "${status.time}", "fontSize": 17, "color": "@colorMuted" },
                    { "type": "Frame", "borderRadius": 999, "borderWidth": 1, "borderColor": "${status.overall.level == 'crit' ? @colorCrit : status.overall.level == 'warn' ? @colorWarn : @colorOk}", "backgroundColor": "${status.overall.level == 'crit' ? '#fb5a7626' : status.overall.level == 'warn' ? '#f7b53b26' : '#46d78726'}", "paddingLeft": 16, "paddingRight": 16, "paddingTop": 8, "paddingBottom": 8,
                      "items": [ { "type": "Text", "text": "${status.overall.text}", "fontSize": 17, "fontWeight": "600", "color": "@colorText" } ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "Container", "direction": "row", "width": "100%", "spacing": 22, "paddingTop": 14,
              "items": [
                { "type": "Frame", "grow": 1, "borderRadius": 16, "borderWidth": 1, "borderColor": "@colorLine", "backgroundColor": "@colorSurface2", "items": [ { "type": "RingGauge", "pct": "${status.cpu.pct}", "value": "${status.cpu.value}", "label": "${status.cpu.label}", "sub": "${status.cpu.sub}", "level": "${status.cpu.level}" } ] },
                { "type": "Frame", "grow": 1, "borderRadius": 16, "borderWidth": 1, "borderColor": "@colorLine", "backgroundColor": "@colorSurface2", "items": [ { "type": "RingGauge", "pct": "${status.ram.pct}", "value": "${status.ram.value}", "label": "${status.ram.label}", "sub": "${status.ram.sub}", "level": "${status.ram.level}" } ] },
                { "type": "Frame", "grow": 1, "borderRadius": 16, "borderWidth": 1, "borderColor": "@colorLine", "backgroundColor": "@colorSurface2", "items": [ { "type": "RingGauge", "pct": "${status.disk.pct}", "value": "${status.disk.value}", "label": "${status.disk.label}", "sub": "${status.disk.sub}", "level": "${status.disk.level}" } ] }
              ]
            },
            {
              "type": "Container", "direction": "row", "width": "100%", "spacing": 20, "paddingTop": 16,
              "items": [
                {
                  "type": "Frame", "grow": 1, "borderRadius": 16, "borderWidth": 1, "borderColor": "@colorLine", "backgroundColor": "@colorSurface2", "paddingLeft": 26, "paddingRight": 26, "paddingTop": 16, "paddingBottom": 16,
                  "items": [
                    {
                      "type": "Container", "spacing": 10,
                      "items": [
                        { "type": "Container", "direction": "row", "justifyContent": "spaceBetween",
                          "items": [
                            { "type": "Text", "text": "DOCKER", "fontSize": 14, "letterSpacing": 3, "color": "@colorBrand" },
                            { "type": "Text", "text": "${status.docker.uptime}", "fontSize": 14, "color": "@colorMuted" }
                          ]
                        },
                        { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 10,
                          "items": [
                            { "type": "Text", "text": "${status.docker.running}", "fontSize": 34, "fontWeight": "800", "color": "@colorText" },
                            { "type": "Text", "text": "/${status.docker.total}", "fontSize": 20, "color": "@colorMuted" },
                            { "type": "Text", "text": "Container laufen", "fontSize": 15, "color": "@colorMuted", "spacing": 6 }
                          ]
                        },
                        { "type": "Frame", "width": "100%", "height": 10, "borderRadius": 5, "backgroundColor": "@colorTrack",
                          "items": [ { "type": "Frame", "width": "${status.docker.pct}%", "height": 10, "borderRadius": 5, "backgroundColor": "@colorOk" } ]
                        },
                        { "type": "Container", "direction": "row", "spacing": 10, "paddingTop": 2,
                          "items": [
                            { "type": "Frame", "borderRadius": 8, "borderWidth": 1, "borderColor": "@colorLine", "paddingLeft": 12, "paddingRight": 12, "paddingTop": 6, "paddingBottom": 6, "items": [ { "type": "Text", "text": "${status.docker.stopped} gestoppt", "fontSize": 15, "color": "@colorMuted" } ] },
                            { "type": "Frame", "when": "${status.docker.unhealthy > 0}", "borderRadius": 8, "borderWidth": 1, "borderColor": "@colorCrit", "backgroundColor": "#fb5a7620", "paddingLeft": 12, "paddingRight": 12, "paddingTop": 6, "paddingBottom": 6, "items": [ { "type": "Text", "text": "${status.docker.unhealthy} ungesund", "fontSize": 15, "color": "#ffdbe2" } ] }
                          ]
                        },
                        { "type": "Text", "when": "${status.docker.names != ''}", "text": "${status.docker.names}", "fontSize": 15, "color": "@colorCrit", "maxLines": 1 }
                      ]
                    }
                  ]
                },
                {
                  "type": "Frame", "grow": 1, "borderRadius": 16, "borderWidth": 1, "borderColor": "@colorLine", "backgroundColor": "@colorSurface2", "paddingLeft": 26, "paddingRight": 26, "paddingTop": 16, "paddingBottom": 16,
                  "items": [
                    {
                      "type": "Container", "spacing": 12,
                      "items": [
                        { "type": "Text", "text": "DIENSTE", "fontSize": 14, "letterSpacing": 3, "color": "@colorBrand" },
                        { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 12, "paddingTop": 2,
                          "items": [
                            { "type": "StatusDot", "level": "${status.services.uptime.level}" },
                            { "type": "Text", "text": "Uptime-Monitore", "fontSize": 20, "color": "@colorText", "grow": 1 },
                            { "type": "Text", "text": "${status.services.uptime.value}", "fontSize": 20, "fontWeight": "600", "color": "@colorText" }
                          ]
                        },
                        { "type": "Text", "when": "${status.services.uptime.note != ''}", "text": "${status.services.uptime.note}", "fontSize": 15, "color": "@colorMuted", "paddingLeft": 24 },
                        { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 12,
                          "items": [
                            { "type": "StatusDot", "level": "${status.services.ssl.level}" },
                            { "type": "Text", "text": "SSL-Zertifikate", "fontSize": 20, "color": "@colorText", "grow": 1 },
                            { "type": "Text", "text": "${status.services.ssl.value}", "fontSize": 20, "fontWeight": "600", "color": "@colorText" }
                          ]
                        },
                        { "type": "Text", "when": "${status.services.ssl.note != ''}", "text": "${status.services.ssl.note}", "fontSize": 15, "color": "@colorMuted", "paddingLeft": 24 }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "Frame", "when": "${status.alerts.length > 0}", "width": "100%", "borderRadius": 12, "borderWidth": 1, "borderColor": "#fb5a7666", "backgroundColor": "#fb5a7614", "paddingLeft": 20, "paddingRight": 20, "paddingTop": 12, "paddingBottom": 12, "marginTop": 14,
              "items": [
                {
                  "type": "Container", "direction": "row", "alignItems": "center", "spacing": 22,
                  "items": [
                    { "type": "Text", "text": "ALERTS", "fontSize": 14, "letterSpacing": 3, "color": "@colorCrit" },
                    { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 24, "data": "${status.alerts}",
                      "items": [
                        { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 10,
                          "items": [
                            { "type": "Frame", "width": 10, "height": 10, "borderRadius": 5, "backgroundColor": "@colorCrit" },
                            { "type": "Text", "text": "${data}", "fontSize": 19, "color": "@colorText", "maxLines": 1 }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "ContainersPage": {
      "parameters": [ { "name": "containers" } ],
      "items": [
        {
          "type": "Container", "width": "100%", "height": "100%", "paddingLeft": 40, "paddingRight": 40, "paddingTop": 28, "paddingBottom": 20,
          "items": [
            {
              "type": "Container", "direction": "row", "alignItems": "center", "justifyContent": "spaceBetween", "width": "100%",
              "items": [
                { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 14,
                  "items": [
                    { "type": "Frame", "width": 30, "height": 30, "borderRadius": 9, "backgroundColor": "@colorBrand" },
                    { "type": "Container",
                      "items": [
                        { "type": "Text", "text": "${containers.title}", "fontSize": 28, "fontWeight": "800", "color": "@colorText" },
                        { "type": "Text", "text": "KyuubiSoft · dev.kyuubisoft.com", "fontSize": 13, "letterSpacing": 2, "color": "@colorMuted" }
                      ]
                    }
                  ]
                },
                { "type": "Container", "direction": "row", "alignItems": "center", "spacing": 10,
                  "items": [
                    { "type": "Frame", "borderRadius": 8, "borderWidth": 1, "borderColor": "@colorLine", "paddingLeft": 12, "paddingRight": 12, "paddingTop": 6, "paddingBottom": 6, "items": [ { "type": "Text", "text": "${containers.summary.running} / ${containers.summary.total} laufen", "fontSize": 15, "color": "@colorText" } ] },
                    { "type": "Frame", "borderRadius": 8, "borderWidth": 1, "borderColor": "@colorLine", "paddingLeft": 12, "paddingRight": 12, "paddingTop": 6, "paddingBottom": 6, "items": [ { "type": "Text", "text": "${containers.summary.stopped} gestoppt", "fontSize": 15, "color": "@colorMuted" } ] },
                    { "type": "Frame", "when": "${containers.summary.unhealthy > 0}", "borderRadius": 8, "borderWidth": 1, "borderColor": "@colorCrit", "backgroundColor": "#fb5a7620", "paddingLeft": 12, "paddingRight": 12, "paddingTop": 6, "paddingBottom": 6, "items": [ { "type": "Text", "text": "${containers.summary.unhealthy} ungesund", "fontSize": 15, "color": "#ffdbe2" } ] }
                  ]
                }
              ]
            },
            {
              "type": "Sequence", "grow": 1, "width": "100%", "scrollDirection": "vertical", "paddingTop": 18, "paddingBottom": 6, "data": "${containers.items}",
              "items": [
                { "type": "ContainerRow", "spacing": 10, "name": "${data.name}", "sub": "${data.sub}", "level": "${data.level}", "cpu": "${data.cpu}", "cpuBar": "${data.cpuBar}", "mem": "${data.mem}", "memBar": "${data.memBar}" }
              ]
            }
          ]
        }
      ]
    }
  },
  "mainTemplate": {
    "parameters": [ "status", "containers", "nav" ],
    "items": [
      {
        "type": "Frame", "width": "100vw", "height": "100vh", "backgroundColor": "@colorBg",
        "items": [
          {
            "type": "Container", "width": "100%", "height": "100%",
            "items": [
              {
                "type": "Pager", "id": "dashPager", "grow": 1, "width": "100%", "navigation": "normal", "initialPage": "${nav.startPage}",
                "items": [
                  { "type": "OverviewPage", "status": "${status}" },
                  { "type": "ContainersPage", "containers": "${containers}" }
                ]
              },
              {
                "type": "Container", "width": "100%", "height": 30, "direction": "row", "justifyContent": "center", "alignItems": "center", "spacing": 12,
                "items": [
                  { "type": "Text", "text": "‹ wischen ·", "fontSize": 13, "color": "@colorMuted" },
                  { "type": "Text", "text": "Übersicht", "fontSize": 13, "color": "@colorBrand", "fontWeight": "600" },
                  { "type": "Text", "text": "·", "fontSize": 13, "color": "@colorMuted" },
                  { "type": "Text", "text": "Container", "fontSize": 13, "color": "@colorBrand", "fontWeight": "600" },
                  { "type": "Text", "text": "›", "fontSize": 13, "color": "@colorMuted" }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
