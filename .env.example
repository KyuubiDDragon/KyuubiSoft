# ===================
# Application
# ===================
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# ===================
# Database (MySQL)
# ===================
DB_DATABASE=kyuubisoft
DB_USERNAME=kyuubisoft
DB_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootpassword

# ===================
# JWT Configuration
# ===================
# WICHTIG: In Produktion einen sicheren 256-bit Key generieren!
# openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-here-change-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ===================
# Application Encryption Keys (REQUIRED)
# ===================
# Used to encrypt stored secrets (API keys, SSH credentials, Docker TLS,
# DB passwords, mail passwords, VAPID push keys, terminal sessions).
# The app refuses to boot if these are missing or set to a placeholder.
# Generate fresh values: openssl rand -hex 32
APP_KEY=replace-with-openssl-rand-hex-32
APP_SECRET=replace-with-openssl-rand-hex-32

# Shared secret used to authenticate the collaboration server when it
# POSTs document content back to the backend. Backend + collaboration
# container MUST share the same value.
# Generate: openssl rand -hex 32
COLLABORATION_HMAC_SECRET=replace-with-openssl-rand-hex-32

# ===================
# Redis
# ===================
REDIS_HOST=redis
REDIS_PORT=6379

# ===================
# Ports (Docker)
# ===================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
MYSQL_PORT=3306
REDIS_PORT=6379
PHPMYADMIN_PORT=8080

# ===================
# Frontend
# ===================
VITE_API_URL=http://localhost/api

# ===================
# Alexa Skill (self-hosted endpoint: POST /api/v1/alexa/webhook)
# ===================
# Skill id from the Alexa Developer Console (amzn1.ask.skill....). When set,
# only requests for this skill are accepted. Leave empty to skip the check.
ALEXA_SKILL_ID=
# Optional: scope uptime/SSL/cron data in Alexa answers to one user id.
# Leave empty to aggregate across all users (single-admin homelab).
ALEXA_USER_ID=
# DANGER: set to true ONLY for local skill testing and never in production.
# Disables Amazon signature/timestamp verification. Ignored when APP_ENV=production.
ALEXA_SKIP_VERIFICATION=false
# Allow controlling containers by voice (start/stop/restart). Off by default.
# Every control command still requires a spoken confirmation ("ja"/"nein").
ALEXA_ALLOW_CONTROL=false
# Optional: comma-separated container names that MAY be controlled by voice.
# Empty = all containers allowed (when ALEXA_ALLOW_CONTROL=true).
ALEXA_CONTROL_ALLOWLIST=
